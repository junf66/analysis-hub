# 設計原則: cache/ と reports/ は再生成可能なため除外
cache/
reports/

# 自社株買いフェッチの中間キャッシュ (イベント一覧。再生成可能・最終データは buyback_records.json)
data/buyback_records_events.json

# atomic_write の一時ファイル (実行中に一瞬残る。rename 後に消える)
**/.*.tmp

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Notebook
.ipynb_checkpoints/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

